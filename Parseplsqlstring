CREATE OR REPLACE PROCEDURE process_string(p_input IN VARCHAR2) IS
    v_first_part  VARCHAR2(100);
    v_second_part VARCHAR2(100);
    v_whole       VARCHAR2(4000);
BEGIN
    IF LENGTH(p_input) >= 4 THEN
        -- Check if first 3 characters are digits and 4th is space
        IF REGEXP_LIKE(SUBSTR(p_input, 1, 3), '^\d{3}$') AND SUBSTR(p_input, 4, 1) = ' ' THEN
            v_first_part  := SUBSTR(p_input, 1, 3);
            v_second_part := SUBSTR(p_input, 5); -- everything after the space
            DBMS_OUTPUT.PUT_LINE('First Part  : ' || v_first_part);
            DBMS_OUTPUT.PUT_LINE('Second Part : ' || v_second_part);
        ELSIF SUBSTR(p_input, 4, 1) != ';' THEN
            v_whole := p_input;
            DBMS_OUTPUT.PUT_LINE('Whole String: ' || v_whole);
        ELSE
            DBMS_OUTPUT.PUT_LINE('Condition not met. No assignment.');
        END IF;
    ELSE
        DBMS_OUTPUT.PUT_LINE('Input too short.');
    END IF;
    
EXCEPTION
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error: ' || SQLERRM);
END;
